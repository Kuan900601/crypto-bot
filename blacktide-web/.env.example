# === 串接黑潮 Bot（與 Railway 上同一組 Upstash）。沒設 → signals 自動用 DEMO 模擬資料 ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# bot.py 寫入全部狀態的 Redis key（bot 目前用 "bot_data"）；會員資料另存 web:user:* 前綴，互不污染
BOT_REDIS_KEY=bot_data

# === 私人模式密碼（Basic Auth）。⚠️ 跑會員收費站台時請「留空」，否則整站被鎖 ===
DASH_PASSWORD=

# === 真實新聞（可選）。沒設 → 新聞退回 mock。行情走 Bybit 公開 API，不需金鑰 ===
CRYPTOPANIC_TOKEN=

# === 會員系統（NextAuth）===
# 產生密鑰：openssl rand -base64 32
NEXTAUTH_SECRET=
# 部署後的完整網址，例如 https://blacktide.vercel.app（IPN / OAuth 回呼需要）
NEXTAUTH_URL=
# 管理員 Email（該帳號永久 Premium）
ADMIN_EMAIL=

# === Google 登入（可選，兩者都設才會開啟）===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 前端按鈕顯示開關（要顯示 Google 登入鈕就設 true）
NEXT_PUBLIC_GOOGLE_ENABLED=

# === NOWPayments 加密貨幣金流 ===
NOWPAYMENTS_API_KEY=
# IPN webhook 簽章密鑰（NOWPayments 後台設定 IPN 時取得，強烈建議設）
NOWPAYMENTS_IPN_SECRET=
# Premium 價格（USD）與天數
PREMIUM_PRICE_USD=29
PREMIUM_DAYS=30
# 前端顯示用價格（與上面一致即可）
NEXT_PUBLIC_PREMIUM_PRICE=29
