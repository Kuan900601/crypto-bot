# === 串接黑潮 Bot（與 Railway 上同一組 Upstash）。沒設 → signals 自動用 DEMO 模擬資料 ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# bot.py 寫入全部狀態的 Redis key（bot 目前用 "bot_data"）
BOT_REDIS_KEY=bot_data

# === 儀表板存取密碼（Basic Auth）。未設 = 公開可見 ===
DASH_PASSWORD=

# === 真實新聞（可選）。沒設 → 新聞退回 mock。行情走 Bybit 公開 API，不需金鑰 ===
CRYPTOPANIC_TOKEN=
