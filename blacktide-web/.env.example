# === Upstash Redis（與 Railway 上 bot 同一組；用戶資料 web:user:* 也存這裡） ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BOT_REDIS_KEY=bot_data
# === NextAuth（必填；腳本已自動寫入 .env.local。Codespaces 預覽請把 URL 改成轉發網址） ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# === 會員：此 Email 註冊後自動成為 Lifetime Premium ===
ADMIN_EMAIL=
# === Google 登入（選填） ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# === 新聞 CryptoPanic（選填；developer v2 可用 BASE 覆寫） ===
CRYPTOPANIC_TOKEN=
CRYPTOPANIC_API_BASE=
# === 美股 Finnhub（選填） ===
FINNHUB_API_KEY=
# === 金流 NOWPayments（之後接金流才填） ===
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
